# Copy this file to .env and fill in your values.

# Local Ollama model. Must support tool calling (qwen3, llama3.1, mistral-nemo, ...).
# Pull it first:  ollama pull qwen3:8b
# HERMES_MODEL=qwen3:8b
# OLLAMA_HOST=http://localhost:11434

# Gmail channel.
# GMAIL_ADDRESS is the assistant's OWN Gmail account (create a dedicated one, e.g. hermes.mybusiness@gmail.com).
# GMAIL_APP_PASSWORD: on that Google account, enable 2-Step Verification, then create an
# App Password at https://myaccount.google.com/apppasswords (16 characters, spaces are ok).
# HERMES_OWNER_EMAIL is YOUR address: results are sent there, and only tasks emailed from it are accepted.
GMAIL_ADDRESS=hermes.mybusiness@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
HERMES_OWNER_EMAIL=you@example.com

# Optional overrides
# HERMES_NUM_CTX=16384
# HERMES_REQUEST_TIMEOUT=600
# HERMES_DATA_DIR=./data
# HERMES_MAX_ITERATIONS=60
# HERMES_POLL_SECONDS=60
