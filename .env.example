# Copy this file to .env and fill in your values.

# Anthropic API key (https://platform.claude.com/)
ANTHROPIC_API_KEY=sk-ant-...

# CallMeBot WhatsApp settings.
# To get an API key: add +34 644 51 95 23 to your phone contacts (name it e.g. CallMeBot)
# and send it the WhatsApp message: "I allow callmebot to send me messages".
# The bot replies with your personal apikey.
CALLMEBOT_PHONE=+4512345678
CALLMEBOT_APIKEY=123456

# Optional overrides
# HERMES_MODEL=claude-opus-4-8
# HERMES_DATA_DIR=./data
# HERMES_MAX_ITERATIONS=60
# HERMES_POLL_SECONDS=60
